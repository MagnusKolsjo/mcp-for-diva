# ── Databasanslutning ──────────────────────────────────────────────────────────
# PostgreSQL (standard — rekommenderas)
DATABASE_URL=postgresql://mitt_db_anvandare:byt_till_eget_starkt_losenord@localhost:5432/riksdagstryck

# SQLite (fallback — inget PostgreSQL behövs)
# DATABASE_URL=sqlite:///diva_cache.db

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio: MCP-klienten startar processen (standard för lokal användning)
# http:  Servern lyssnar på MCP_HOST:MCP_PORT (för hostad driftsättning)
MCP_TRANSPORT=stdio

# ── HTTP-transport (används bara om MCP_TRANSPORT=http) ───────────────────────
MCP_HOST=127.0.0.1
MCP_PORT=8015
# Generera nyckel med: python3 -c "import secrets; print(secrets.token_hex(32))"
MCP_API_KEY=

# ── Flerspråkig begreppsexpansion (valfri) ────────────────────────────────────
# Expanderar söktermer till ekvivalenter på sv/en/fr/de/no/da via AI-endpoint
QUERY_EXPANSION_ENABLED=false
# QUERY_EXPANSION_API_URL=https://api.anthropic.com/v1/messages
# QUERY_EXPANSION_API_KEY=din-api-nyckel
# QUERY_EXPANSION_MODEL=claude-haiku-4-5-20251001

# ── Epistemisk status — grundpoäng per publikationstyp (1–5) ─────────────────
EPISTEMISK_DOKTORSAVHANDLING=5
EPISTEMISK_LICENTIATAVHANDLING=4
EPISTEMISK_ARTIKEL_GRANSKAD=4
EPISTEMISK_BOK=3
EPISTEMISK_KONFERENSBIDRAG_GRANSKAD=3
EPISTEMISK_RAPPORT=2
EPISTEMISK_EXAMENSARBETE_AVANCERAD=2
EPISTEMISK_EXAMENSARBETE_GRUND=1
EPISTEMISK_OVRIG=1

# ── PDF-cache ─────────────────────────────────────────────────────────────────
# PDF_CACHE_DIR=./pdf_cache   (standard: mappen 'pdf_cache' bredvid skriptet)
PDF_CACHE_TTL_DAGAR=7
